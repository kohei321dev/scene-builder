# Do not put real secrets in this file.

# Set one of these after deciding the AI provider.
GROK_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
# Current xAI docs recommend Grok 4.3 for general text.
# Keep this as an env var so we can switch models without code changes.
GROK_MODEL=grok-4.3
# AI review is a simple coaching task, so disable reasoning by default.
GROK_REASONING_EFFORT=none

# Used by the app to choose the provider adapter.
# Allowed examples: groq, xai
AI_PROVIDER=xai

# GitHub OAuth for Auth.js / NextAuth.
# Callback URL:
#   https://your-vercel-url/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=

# Owner allowlist for the first authenticated version.
OWNER_GITHUB_USERNAME=kohei321dev

# Neon/Postgres practice record persistence.
DATABASE_URL=

# Local UI verification only. This is ignored when NODE_ENV=production.
DEV_AUTH_BYPASS=1
