# Do not put real secrets in this file.

# Set one of these after deciding the AI provider.
GROQ_API_KEY=
XAI_API_KEY=

# Used by the app to choose the provider adapter.
# Allowed examples: groq, xai
AI_PROVIDER=groq

# GitHub OAuth for Auth.js / NextAuth.
# Callback URL:
#   https://your-vercel-url/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=

# Owner allowlist for the first authenticated version.
OWNER_GITHUB_USERNAME=kohei321dev

# Local UI verification only. This is ignored when NODE_ENV=production.
DEV_AUTH_BYPASS=1
